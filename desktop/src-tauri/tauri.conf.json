{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lihua",
  "version": "0.8.26",
  "identifier": "cn.lihua.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "狸花猫",
        "url": "index.html",
        "width": 720,
        "height": 640,
        "minWidth": 480,
        "minHeight": 480,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
